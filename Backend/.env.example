# ==========================================
# FILE MẪU: .env.example
# Đổi tên file này thành .env trước khi chạy
# ==========================================

# --- Database & Cache ---
ConnectionStrings__DefaultConnection=your_mongodb_connection_string_here
ConnectionStrings__RedisConnection=your_redis_connection_string_here

# --- JWT Configuration ---
Jwt__Key=your_super_secret_jwt_key_here
Jwt__Issuer=your_jwt_issuer_here
Jwt__Audience=your_jwt_audience_here

# --- Google Authentication ---
GoogleAuthentication__ClientId=your_google_client_id_here
GoogleAuthentication__AppPassword=your_google_app_password_here

# --- Facebook Authentication ---
FacebookAuthentication__AppId=your_facebook_app_id_here
FacebookAuthentication__AppSecret=your_facebook_app_secret_here
FacebookAuthentication__Url=your_facebook_url_here

# --- Cloudinary (Image Storage) ---
Cloudinary__CloudName=your_cloudinary_name_here
Cloudinary__ApiKey=your_cloudinary_api_key_here
Cloudinary__ApiSecret=your_cloudinary_api_secret_here
Cloudinary__UploadPreset=your_cloudinary_upload_preset_here

# --- Sepay (Payment Gateway) ---
Sepay__ApiKey=your_sepay_api_key_here

# --- Province API (Address lookup) ---
ProvinceApi__BaseUrl=https://provinces.open-api.vn/api/v2/

# --- Chatbot AI Configuration ---
# ActiveProvider: Ollama | Gemini
Chatbot__ActiveProvider=Gemini

# Ollama Settings
Chatbot__Ollama__Model=llama3
Chatbot__Ollama__ApiKey=your_ollama_api_key_here
Chatbot__Ollama__Url=http://localhost:11434
Chatbot__Ollama__EmbeddingModel=your_ollama_embedding_model_here

# Gemini Settings
Chatbot__Gemini__Model=gemini-3.1-flash-lite
Chatbot__Gemini__ApiKey=your_gemini_api_key_here
Chatbot__Gemini__EmbeddingModel=gemini-embedding-001

# --- Grafana Configuration ---
Grafana__Admin__User=your_grafana_admin_user_here
Grafana__Admin__Password=your_grafana_admin_password_here